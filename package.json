{
  "name": "rn-smart-sheet",
  "version": "1.0.1-beta.12",
  "description": "A performant bottom sheet component for React Native with Reanimated 2-4 support and integrated keyboard management",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "react-native.config.js",
    "RNSmartSheet.podspec",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "clean": "rimraf lib",
    "generate-nitro": "nitrogen"
  },
  "keywords": [
    "react-native",
    "bottom-sheet",
    "bottomsheet",
    "modal",
    "reanimated",
    "gesture-handler",
    "keyboard",
    "smart-sheet",
    "ios",
    "android"
  ],
  "author": "Paresh Chavda",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pareshchavda/rn-smart-sheet.git"
  },
  "bugs": {
    "url": "https://github.com/pareshchavda/rn-smart-sheet/issues"
  },
  "homepage": "https://github.com/pareshchavda/rn-smart-sheet#readme",
  "codegenConfig": {
    "name": "RNSmartSheetSpec",
    "type": "all",
    "jsSrcsDir": "src/specs",
    "android": {
      "javaPackageName": "com.rnsmartsheet"
    },
    "ios": {
      "componentProvider": {
        "RNSmartSheetView": "RNSmartSheetViewComponentView"
      }
    }
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-gesture-handler": "*",
    "react-native-reanimated": "*",
    "react-native-nitro-modules": "*"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "react": "^18.2.0",
    "react-native": "^0.80.0",
    "react-native-codegen": "0.72.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-nitro-modules": "^0.35.7",
    "react-native-reanimated": "4.2.1",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0"
  }
}
