{
  "name": "rn-smart-sheet",
  "version": "1.0.1-beta.2",
  "description": "A performant bottom sheet component for React Native with Reanimated 2-4 support and integrated keyboard management",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "react-native.config.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "clean": "rimraf lib"
  },
  "keywords": [
    "react-native",
    "bottom-sheet",
    "bottomsheet",
    "modal",
    "reanimated",
    "gesture-handler",
    "keyboard",
    "smart-sheet",
    "ios",
    "android"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "codegenConfig": {
    "name": "RNSmartSheetSpec",
    "type": "all",
    "jsSrcsDir": "src/specs",
    "android": {
      "javaPackageName": "com.rnsmartsheet"
    },
    "ios": {
      "componentProvider": {
        "RNSmartSheetView": "RNSmartSheetViewComponentView"
      }
    }
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "react": "^18.2.0",
    "react-native": "^0.72.0",
    "react-native-codegen": "^0.72.8",
    "typescript": "^5.3.0",
    "rimraf": "^5.0.0"
  }
}